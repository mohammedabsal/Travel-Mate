generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum TripStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

enum Visibility {
  PRIVATE
  SHARED
  PUBLIC
}

enum ExpenseCategory {
  TRANSPORTATION
  ACCOMMODATION
  FOOD
  ACTIVITIES
  SHOPPING
  OTHER
}

model User {
  id               String            @id @default(cuid())
  name             String?
  email            String            @unique
  emailVerified    DateTime?
  image            String?
  passwordHash     String?
  phone            String?
  city             String?
  country          String?
  role             String            @default("USER")
  locale           String            @default("en")
  currency         String            @default("USD")
  timezone         String            @default("UTC")
  bio              String?
  preferences      Json?
  createdAt        DateTime          @default(now())
  updatedAt        DateTime          @updatedAt
  trips            Trip[]
  journalEntries   JournalEntry[]
  checklistItems   ChecklistItem[]
  savedDestinations Destination[]     @relation("SavedDestinations")
  accounts         Account[]
  sessions         Session[]

  @@index([email])
}

model Destination {
  id           String         @id @default(cuid())
  name         String
  city         String
  region       String?
  country      String
  countryCode  String?
  slug         String         @unique
  description  String?
  imageUrl     String?
  latitude     Float?
  longitude    Float?
  costIndex    Int            @default(100)
  currency     String         @default("USD")
  isFeatured   Boolean        @default(false)
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt
  trips        TripStop[]
  activities   Activity[]
  savedBy      User[]         @relation("SavedDestinations")

  @@index([country])
  @@index([region])
  @@index([city])
}

model ActivityCategory {
  id         String     @id @default(cuid())
  name       String     @unique
  slug       String     @unique
  icon       String?
  createdAt  DateTime   @default(now())
  updatedAt  DateTime   @updatedAt
  activities Activity[]
}

model Activity {
  id             String          @id @default(cuid())
  destinationId  String?
  categoryId     String
  name           String
  description    String?
  durationMins   Int
  estimatedCost  Decimal         @default(0) @db.Decimal(10, 2)
  rating         Float           @default(0)
  bookingUrl     String?
  isOutdoor      Boolean         @default(false)
  metadata       Json?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  destination    Destination?    @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  category       ActivityCategory @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  tripActivities TripActivity[]

  @@index([destinationId])
  @@index([categoryId])
}

model Trip {
  id              String          @id @default(cuid())
  ownerId         String
  title           String
  description     String?
  coverImageUrl   String?
  startDate       DateTime
  endDate         DateTime
  status          TripStatus      @default(DRAFT)
  visibility      Visibility      @default(PRIVATE)
  shareSlug       String?         @unique
  currency        String          @default("USD")
  budgetTarget    Decimal?        @db.Decimal(12, 2)
  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt
  owner           User            @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  stops           TripStop[]
  activities      TripActivity[]
  budget          Budget?
  checklist       Checklist?
  checklistItems  ChecklistItem[]
  journalEntries  JournalEntry[]
  sharedTrip      SharedTrip?
  expenses        Expense[]

  @@index([ownerId, startDate])
  @@index([visibility, startDate])
}

model TripStop {
  id                  String        @id @default(cuid())
  tripId              String
  destinationId       String?
  order               Int
  city                String
  region              String?
  country             String
  arrivalDate         DateTime?
  departureDate       DateTime?
  notes               String?
  latitude            Float?
  longitude           Float?
  dailyBudgetEstimate Decimal?      @db.Decimal(12, 2)
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  trip                Trip          @relation(fields: [tripId], references: [id], onDelete: Cascade)
  destination         Destination?  @relation(fields: [destinationId], references: [id], onDelete: SetNull)
  tripActivities      TripActivity[]
  journalEntries      JournalEntry[]

  @@index([tripId, order])
  @@index([destinationId])
}

model TripActivity {
  id               String      @id @default(cuid())
  tripId           String
  tripStopId       String?
  activityId       String
  scheduledDateTime DateTime?
  notes            String?
  order            Int         @default(0)
  isBooked         Boolean     @default(false)
  costEstimate     Decimal?    @db.Decimal(12, 2)
  createdAt        DateTime    @default(now())
  updatedAt        DateTime    @updatedAt
  trip             Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  tripStop         TripStop?   @relation(fields: [tripStopId], references: [id], onDelete: SetNull)
  activity         Activity    @relation(fields: [activityId], references: [id], onDelete: Cascade)
  expenses         Expense[]

  @@index([tripId, order])
  @@index([tripStopId])
  @@index([activityId])
}

model Budget {
  id            String      @id @default(cuid())
  tripId        String      @unique
  currency      String      @default("USD")
  totalPlanned  Decimal     @default(0) @db.Decimal(12, 2)
  totalSpent    Decimal     @default(0) @db.Decimal(12, 2)
  dailyAverage  Decimal     @default(0) @db.Decimal(12, 2)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  trip          Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  expenses      Expense[]

  @@index([tripId])
}

model Expense {
  id             String          @id @default(cuid())
  budgetId       String
  tripId         String
  tripActivityId String?
  title          String
  amount         Decimal         @db.Decimal(12, 2)
  category       ExpenseCategory
  expenseDate    DateTime
  vendor         String?
  notes          String?
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  budget         Budget         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  trip           Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  activity       TripActivity?  @relation(fields: [tripActivityId], references: [id], onDelete: SetNull)

  @@index([budgetId])
  @@index([tripId])
  @@index([tripActivityId])
}

model Checklist {
  id          String         @id @default(cuid())
  tripId      String         @unique
  title       String         @default("Packing checklist")
  progress    Float          @default(0)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  trip        Trip           @relation(fields: [tripId], references: [id], onDelete: Cascade)
  items       ChecklistItem[]

  @@index([tripId])
}

model ChecklistItem {
  id           String      @id @default(cuid())
  checklistId  String
  tripId       String
  userId       String?
  label        String
  category     String
  isPacked     Boolean     @default(false)
  quantity     Int         @default(1)
  notes        String?
  packedAt     DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  checklist    Checklist   @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  trip         Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([tripId, isPacked])
  @@index([checklistId])
}

model JournalEntry {
  id           String      @id @default(cuid())
  tripId       String
  userId       String?
  tripStopId   String?
  title        String
  content      String
  entryDate    DateTime
  isPrivate    Boolean     @default(true)
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  trip         Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)
  user         User?       @relation(fields: [userId], references: [id], onDelete: SetNull)
  stop         TripStop?   @relation(fields: [tripStopId], references: [id], onDelete: SetNull)

  @@index([tripId, entryDate])
}

model SharedTrip {
  id           String      @id @default(cuid())
  tripId       String      @unique
  slug         String      @unique
  isPublic     Boolean     @default(false)
  copiedCount  Int         @default(0)
  expiresAt    DateTime?
  createdAt    DateTime    @default(now())
  updatedAt    DateTime    @updatedAt
  trip         Trip        @relation(fields: [tripId], references: [id], onDelete: Cascade)

  @@index([slug])
}

model Account {
  id                String   @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?  @db.Text
  access_token      String?  @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?  @db.Text
  session_state     String?
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken  String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}